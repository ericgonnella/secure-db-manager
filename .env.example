# Sample environment for `docker compose up`. Copy to `.env` and replace
# every value with a freshly-generated secret. NEVER commit the real `.env`.
#
# Generate a 32-char secret with:    openssl rand -base64 32

# AES-256-GCM master key for the secrets file. >=32 chars.
BASEPORT_SECRET_KEY=replace-me-with-32-or-more-random-chars-aaaa

# Initial admin password (>=8 chars). Stored as bcrypt at startup; the
# plaintext is only read once.
BASEPORT_ADMIN_PASSWORD=replace-me-min-8-chars

# JWT signing secret. >=32 chars. Rotating this invalidates every issued token.
BASEPORT_JWT_SECRET=replace-me-with-32-or-more-random-chars-bbbb

# Origin allowed by the CORS layer. Set to your public URL in production.
# Leave blank during development to allow any origin (NOT for production).
BASEPORT_ALLOWED_ORIGIN=https://baseport.example.com

# Optional: token lifetime in hours (default 24).
BASEPORT_TOKEN_EXPIRY_HOURS=24

# Optional: tracing filter.
RUST_LOG=info,tower_http=info
